# サイトの公開URL（OGP・canonical・sitemap に使用）
NEXT_PUBLIC_SITE_URL=https://haruju-homecare-site.vercel.app

# ───────────────────────────────
# お知らせ（/news）: WordPress REST API
# ───────────────────────────────
# WordPressの REST API ベースURL（末尾の /wp-json/wp/v2 まで含める）
# 例) https://wp.example.com/wp-json/wp/v2
# 未設定のあいだは lib/news.ts のフォールバック記事が表示され、サイトは正常に動作します。
NEXT_PUBLIC_WP_API_BASE_URL=

# ───────────────────────────────
# 専門コラム（/column）: 自動生成（GitHub Actions で使用）
# ───────────────────────────────
# ローカルで scripts/generate-daily-column.ts を試す場合のみ必要。
# 本番の自動生成は GitHub Secrets の ANTHROPIC_API_KEY を使用します。
ANTHROPIC_API_KEY=
# 省略時は claude-haiku-4-5-20251001 を使用
ANTHROPIC_MODEL=
